# ─────────────────────────────────────────────────────────────────────────────
# Wallet / Auth (REQUIRED for live trading)
# ─────────────────────────────────────────────────────────────────────────────

# Polygon private key (the L1 key controlling your Polymarket account)
PRIVATE_KEY=<Polymarket Private Key>

# Proxy wallet (funder) address — find at polymarket.com/settings
FUNDER_ADDRESS=<Polygon Funder Address>

# Signature type: 0=EOA, 1=MagicLink, 2=Browser/Google proxy wallet
SIGNATURE_TYPE=2


# ─────────────────────────────────────────────────────────────────────────────
# Safety
# ─────────────────────────────────────────────────────────────────────────────

# "false" = REAL trading. Default true = no real orders placed.
DRY_RUN=true


# ─────────────────────────────────────────────────────────────────────────────
# Bot behaviour
# ─────────────────────────────────────────────────────────────────────────────

# How often (seconds) to refresh prices in the poll loop
POLLING_INTERVAL=1

# Real-time price streaming. "false" = REST polling only.
USE_WEBSOCKET=true

# Max allowed price jump between ticks (0.0–1.0). Larger moves trigger a
# REST confirmation before the price is accepted.
SPIKE_THRESHOLD=0.15

# Seconds to wait after a new market opens before trading (0 = no rest)
MARKET_REST_SECONDS=480

# Poll interval (seconds) for the live BTC price (Pyth Hermes oracle).
# Below 3 risks rate limits; below 1 risks IP bans.
BTC_PRICE_POLL_SECONDS=3.0


# ─────────────────────────────────────────────────────────────────────────────
# Arbitrage
# ─────────────────────────────────────────────────────────────────────────────

# Master switch for arbitrage detection
ARB_ENABLED=true

# Minimum net profit ($) to flag an arb opportunity
ARB_MIN_PROFIT=0.005

# Minimum ROI % to flag as worth taking
ARB_MIN_ROI_PCT=0.3

# Auto-execute detected arbitrage trades
AUTO_EXECUTE=false

# Max shares per arbitrage execution
MAX_POSITION_SIZE=100

# Cooldown (seconds) between executions on the same market
ARB_COOLDOWN_SECONDS=120


# ─────────────────────────────────────────────────────────────────────────────
# Risk management
# ─────────────────────────────────────────────────────────────────────────────

# Hard cap on total $ deployed
MAX_BUDGET=1000

# Max simultaneously open positions
MAX_CONCURRENT_POSITIONS=3

# Max loss per single trade ($)
MAX_LOSS_PER_TRADE=10

# Max cumulative daily loss ($)
MAX_DAILY_LOSS=50

# Stop-loss enforcement
STOP_LOSS_ENABLED=false
STOP_LOSS_AMOUNT=100


# ─────────────────────────────────────────────────────────────────────────────
# Directional buys (independent of arbitrage)
# ─────────────────────────────────────────────────────────────────────────────

# Buy YES shares when YES ask >= this threshold (0.0 = disabled)
BUY_YES_TRIGGER=0.87

# Buy NO shares when NO ask >= this threshold (0.0 = disabled)
BUY_NO_TRIGGER=0.87

# Maximum price the bot will pay for a directional buy (0 = no cap)
MAX_BUY_PRICE=0.96

# Shares per directional trigger
DIRECTIONAL_BUY_SIZE=50


# ─────────────────────────────────────────────────────────────────────────────
# Market resolution
# ─────────────────────────────────────────────────────────────────────────────

# Bid level at which we infer the winning side on market close.
# Tighter values (e.g. 0.95) avoid mis-labelling thin-book late spikes.
WIN_DETECT_THRESHOLD=0.85


# ─────────────────────────────────────────────────────────────────────────────
# Telegram notifications (optional)
# Get token from @BotFather, chat ID from @userinfobot
# ─────────────────────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=<Telegram Bot Token>
TELEGRAM_CHAT_ID=<Telegram Chat ID>


# ─────────────────────────────────────────────────────────────────────────────
# Dashboard / Docker (advanced — defaults usually fine)
# ─────────────────────────────────────────────────────────────────────────────

# Port the web dashboard binds to
# DASHBOARD_PORT=8080

# Allow non-loopback clients (Docker host → container). The CSRF Origin
# check still applies to state-changing requests.
# ALLOW_REMOTE_DASHBOARD=false

# "cli" hides desktop-only UI (updater, uninstall, channel selector).
# Docker sets this automatically; leave unset for the native .app build.
# POLYBOT_RUNTIME_MODE=cli
