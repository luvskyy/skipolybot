# Your Polygon private key (the L1 key that controls your Polymarket account)
PRIVATE_KEY=

# Your proxy wallet (funder) address — find this at polymarket.com/settings
# Look for the wallet address shown in your profile dropdown
FUNDER_ADDRESS=

# Signature type: 0=EOA, 1=MagicLink, 2=Browser/Google proxy wallet
SIGNATURE_TYPE=2

# Safety: set to "false" to enable REAL trading (default: true = no real orders)
DRY_RUN=true

# Polling interval in seconds (how often to refresh prices)
POLLING_INTERVAL=5

# Auto-execution: set to "true" to automatically execute detected arbitrage trades
AUTO_EXECUTE=false

# Maximum shares per arbitrage execution
MAX_POSITION_SIZE=100

# Cooldown in seconds between executions on the same market
ARB_COOLDOWN_SECONDS=120
MARKET_REST_SECONDS=

# WebSocket: set to "false" to disable real-time price streaming (REST polling only)
USE_WEBSOCKET=true

# Spike filter: max price jump before REST confirmation (0.0–1.0)
SPIKE_THRESHOLD=0.15

# Directional buy triggers (0.0 = disabled)
# Buy YES shares when YES ask price >= this threshold
BUY_YES_TRIGGER=0.0
# Buy NO shares when NO ask price >= this threshold
BUY_NO_TRIGGER=0.0
# Number of shares to buy per directional trigger
DIRECTIONAL_BUY_SIZE=50

# Telegram notifications (optional): get a token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
